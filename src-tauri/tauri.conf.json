{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nodemind",
  "version": "0.1.0",
  "identifier": "com.nokast.nodemind",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nodemind",
        "width": 1060,
        "height": 720,
        "minWidth": 820,
        "minHeight": 580,
        "resizable": true,
        "minimizable": true,
        "maximizable": true,
        "closable": true,
        "alwaysOnTop": false,
        "transparent": false,
        "decorations": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/prompts.toml",
      "resources/models/ggml-small.bin",
      "resources/models/ggml-small-encoder.mlmodelc/**/*"
    ]
  }
}
